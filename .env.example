# Environment Configuration Example
# Copy this to .env and update with your values

# FastAPI Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./compliance_autopilot.db

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# Notification Configuration
DASHBOARD_URL=http://localhost:8000

# Celery (for async tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Redis (for caching and notifications)
REDIS_URL=redis://localhost:6379/0

# OpenAI (for NLP processing)
OPENAI_API_KEY=sk-your-key-here

# RBI Circular Source Configuration
RBI_CIRCULAR_SOURCE_URL=https://www.rbi.org.in/Scripts/BS_CircularIndexPage.aspx
